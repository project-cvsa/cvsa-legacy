{
	"include": ["**/*.ts"],
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["bun"],
		"strict": true,
		"useDefineForClassFields": true,
		"allowImportingTsExtensions": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"paths": {
			"*": ["./*"],
			"@core/*": ["../core/*"]
		},
		"allowSyntheticDefaultImports": true,
		"noEmit": true
	}
}
